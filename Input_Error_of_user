DECLARE @‚ÄåStartDate DATETIME = '2025-06-26 00:00:00';

DECLARE @‚ÄåEndDate DATETIME = '2025-06-26 23:59:59';



SELECT TOP 1

pt.visible_patient_id AS [HN],

pfn2.display_name_l AS [User Name],

efn.display_name_l AS [Physician Name],

pco.enter_date_time AS [First Entry Time],

pco.external_description AS [Template Used]

FROM AmalgaPROD.dbo.patient_clinical_observation pco

LEFT JOIN AmalgaPROD.dbo.patient_visit pv ON pco.patient_visit_id = pv.patient_visit_id

LEFT JOIN AmalgaPROD.dbo.patient pt ON pv.patient_id = pt.patient_id

LEFT JOIN AmalgaPROD.dbo.person_formatted_name_iview_nl_view pfn2 ON pco.entered_by_employee_id = pfn2.person_id

LEFT JOIN AmalgaPROD.dbo.user_account ua ON pfn2.person_id = ua.person_id

LEFT JOIN AmalgaPROD.dbo.employee_formatted_name_iview efn ON ua.person_id = efn.person_id

WHERE efn.display_name_l LIKE '%Sevilla%'

AND pco.enter_date_time BETWEEN @‚ÄåStartDate AND @‚ÄåEndDate

AND pco.inactivated_date_time IS NULL

ORDER BY pco.enter_date_time ASC;
