DECLARE @date_start DATETIME = '2026-03-01 00:00:00';
 
SELECT
    CONVERT(DATE, pc.lu_updated) AS [Date Completed],
    pf.display_name_l AS [Patient Name],
    ph.visible_patient_id AS [HN],
    ua.display_name_l AS [Completed By],
    COUNT(DISTINCT pc.patient_clinical_observation_id) AS [CF2 Count],
    MIN(pc.lu_updated) AS [First Completed Time],
    MAX(pc.lu_updated) AS [Last Completed Time]
 
FROM patient_clinical_observation pc
 
INNER JOIN api_patient_clinical_observation_detail_view v
ON v.patient_clinical_observation_id = pc.patient_clinical_observation_id
 
LEFT JOIN person_formatted_name_iview pf
ON pc.patient_id = pf.person_id
 
LEFT JOIN patient_hospital_usage ph
ON ph.patient_id = pc.patient_id
 
LEFT JOIN employee_formatted_name_iview ua
ON ua.person_id = v.verified_by_employee_id
 
WHERE pc.external_description LIKE '%CF4%'
AND pc.lu_updated >= @date_start
AND v.verified_by_employee_id IS NOT NULL
 
GROUP BY
CONVERT(DATE, pc.lu_updated),
pf.display_name_l,
ph.visible_patient_id,
ua.display_name_l
 
ORDER BY
[Date Completed] DESC,
[Patient Name];



